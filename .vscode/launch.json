{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug test_property_graph",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/tests/test_property_graph",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build (Debug)"
        },
        {
            "name": "Debug test_materials",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/tests/test_materials",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build (Debug)"
        },
        {
            "name": "Debug test_damage",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/tests/test_damage",
            "args": ["--gtest_filter=TangentCheckerTest.*", "--gtest_also_run_disabled_tests"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build (Debug)"
        },
        {
            "name": "Debug specific test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_debug/tests/${input:testBinary}",
            "args": ["--gtest_filter=${input:testFilter}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake Build (Debug)"
        }
    ],
    "inputs": [
        {
            "id": "testBinary",
            "type": "pickString",
            "description": "Select test binary",
            "options": ["test_property_graph", "test_materials", "test_damage"]
        },
        {
            "id": "testFilter",
            "type": "promptString",
            "description": "GTest filter (e.g. TestSuite.TestName or * for all)",
            "default": "*"
        }
    ]
}
